{
  "name": "tailnews",
  "version": "1.0.0",
  "description": "Tailwind News Template",
  "main": "gulpfile.js",
  "dependencies": {
    "@splidejs/splide": "^4.0.1",
    "@splidejs/splide-extension-video": "^0.7.1",
    "glightbox": "^3.2.0",
    "hc-sticky": "^2.2.7",
    "tailwindcss": "^3.0.24"
  },
  "devDependencies": {
    "acorn": "^8.5.0",
    "autoprefixer": "^10.2.6",
    "browser-sync": "^3.0.4",
    "del": "^6.0.0",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-postcss": "^9.0.0",
    "gulp-purgecss": "^3.1.3",
    "gulp-replace": "^1.1.3",
    "gulp-terser": "^2.0.1",
    "log-symbols": "^4.1.0",
    "wrangler": "^4.110.0"
  },
  "scripts": {
    "dev": "gulp",
    "start": "gulp",
    "signal:stub": "node server/signal-engine-stub.js",
    "signal:health": "node -e \"fetch('http://localhost:4177/health').then(r=>r.text()).then(console.log).catch(e=>{console.error(e.message);process.exit(1);})\"",
    "dev:fresh": "npm run dev:stop && npm run dev",
    "dev:stop": "pkill -f \"gulp|browser-sync\" || true",
    "dev:status": "lsof -iTCP -sTCP:LISTEN -nP | grep -E \"3100|3101|3001|3002\" || true",
    "build": "gulp prod",
    "prod": "gulp prod",
    "updatevendors": "gulp updatevendors",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aribudin/tailnews.git"
  },
  "keywords": [
    "Newspapper",
    "Template",
    "News",
    "tailwindcss",
    "Magazine"
  ],
  "author": "Aribudin",
  "license": "ISC",
  "bugs": {
    "url": "https://tailwindtemplate.net/support/"
  },
  "homepage": "https://tailwindtemplate.net/",
  "directories": {
    "doc": "docs"
  }
}
